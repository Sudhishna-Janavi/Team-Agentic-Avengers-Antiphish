{
  "manifest_version": 3,
  "name": "Antiphish",
  "version": "1.0",
  "description": "AI-powered digital safety sentry for real-time phishing detection.",
  "author": "agentic avengers",
  
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "declarativeNetRequest",
    "scripting",
    "offscreen"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/shield16.png"
    } 
  },

  "icons": {
    "16": "icons/shield16.png",
    "48": "icons/shield16.png",
    "128": "icons/shield16.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "model/*.onnx",
        "lib/*.wasm",
        "lib/*.mjs",
        "icons/phishing.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}